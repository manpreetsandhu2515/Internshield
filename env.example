# ─── Firebase Client (Vite exposes VITE_* vars to browser) ───────────────────
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# ─── Netlify Function (server-side, never exposed to browser) ─────────────────
# These are set in Netlify Dashboard → Site Settings → Environment Variables
# For LOCAL dev copy them into netlify/.env  (netlify dev reads this automatically)
GROQ_API_KEY=YOUR_GROQ_API_KEY

# Firebase Admin (service account JSON as a single-line string)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
